<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#020206" />
        </shape>
    </item>
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#009D00FF"
                android:centerColor="#999D00FF"
                android:endColor="#009D00FF"
                android:type="linear" />
            <size android:height="1dp" />
        </shape>
    </item>
</layer-list>
