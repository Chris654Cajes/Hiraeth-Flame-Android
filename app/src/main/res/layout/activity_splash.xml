<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:fitsSystemWindows="true">

    <!-- Vertical centering guide -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_center_v"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.42" />

    <!-- App Icon -->
    <ImageView
        android:id="@+id/splashIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter"
        android:src="@drawable/app_icon"
        app:layout_constraintBottom_toTopOf="@id/guide_center_v"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="20dp"/>

    <!-- App Name -->
    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:letterSpacing="0.18"
        android:text="@string/app_name"
        android:textAllCaps="true"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guide_center_v" />

    <!-- Neon divider accent under title -->
    <View
        android:id="@+id/splash_divider"
        android:layout_width="120dp"
        android:layout_height="1.5dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/divider_neon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splashTitle" />

    <!-- Tagline quote -->
    <TextView
        android:id="@+id/splashQuote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="60dp"
        android:alpha="0.75"
        android:gravity="center"
        android:text="@string/splash_credit"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.03"
        app:layout_constraintBottom_toTopOf="@id/splashAuthor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Author -->
    <TextView
        android:id="@+id/splashAuthor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="44dp"
        android:alpha="0.55"
        android:gravity="center"
        android:text="@string/splash_author"
        android:textColor="@color/neon_violet"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
