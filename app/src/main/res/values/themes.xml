<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════
         ROOT THEME
    ══════════════════════════════════════════════════ -->
    <style name="Theme.HiraethFlame" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/neon_violet</item>
        <item name="colorOnPrimary">@color/bg_abyss</item>
        <item name="colorPrimaryContainer">@color/neon_violet_dim</item>
        <item name="colorOnPrimaryContainer">@color/neon_violet_bright</item>

        <item name="colorSecondary">@color/neon_cyan</item>
        <item name="colorOnSecondary">@color/bg_abyss</item>
        <item name="colorSecondaryContainer">@color/bg_elevated</item>
        <item name="colorOnSecondaryContainer">@color/neon_cyan</item>

        <item name="colorTertiary">@color/neon_magenta</item>
        <item name="colorOnTertiary">@color/bg_abyss</item>

        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_card</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="colorOutline">@color/neon_violet</item>
        <item name="colorOutlineVariant">@color/border_subtle</item>

        <item name="android:statusBarColor">@color/bg_abyss</item>
        <item name="android:navigationBarColor">@color/bg_abyss</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Component styles -->
        <item name="materialButtonStyle">@style/Btn.Neon</item>
        <item name="materialCardViewStyle">@style/Card.Neon</item>
        <item name="bottomNavigationStyle">@style/BottomNav.Neon</item>
        <item name="toolbarStyle">@style/Toolbar.Neon</item>
        <item name="textInputStyle">@style/TextInput.Neon</item>
        <item name="floatingActionButtonStyle">@style/FAB.Neon</item>
        <item name="materialAlertDialogTheme">@style/Dialog.Neon</item>
        <item name="seekBarStyle">@style/Seekbar.Neon</item>
    </style>


    <!-- ══════════════════════════════════════════════════
         BUTTONS
    ══════════════════════════════════════════════════ -->
    <!-- Primary outlined neon button -->
    <style name="Btn.Neon" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/neon_violet</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/neon_violet</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:elevation">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="rippleColor">#33BF5FFF</item>
    </style>

    <!-- Filled neon violet button -->
    <style name="Btn.Neon.Filled" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/bg_abyss</item>
        <item name="backgroundTint">@color/neon_violet</item>
        <item name="strokeWidth">0dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:elevation">0dp</item>
        <item name="rippleColor">#44FFFFFF</item>
    </style>

    <!-- Tonal / ghost -->
    <style name="Btn.Neon.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textColor">@color/neon_violet</item>
        <item name="backgroundTint">@color/bg_elevated</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Danger text button -->
    <style name="Btn.Danger" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/neon_magenta</item>
        <item name="rippleColor">#33FF007A</item>
    </style>

    <!-- Keep old alias alive -->
    <style name="CyberpunkButton" parent="Btn.Neon" />
    <style name="CyberpunkTonalButton" parent="Btn.Neon.Tonal" />


    <!-- ══════════════════════════════════════════════════
         CARDS
    ══════════════════════════════════════════════════ -->
    <style name="Card.Neon" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Card.Neon.Violet" parent="Card.Neon">
        <item name="strokeColor">@color/neon_violet</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Card.Neon.Cyan" parent="Card.Neon">
        <item name="strokeColor">@color/neon_cyan</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Keep old alias -->
    <style name="CyberpunkCard" parent="Card.Neon" />


    <!-- ══════════════════════════════════════════════════
         BOTTOM NAVIGATION
    ══════════════════════════════════════════════════ -->
    <style name="BottomNav.Neon" parent="Widget.Material3.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.BottomNav.Neon</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="ThemeOverlay.BottomNav.Neon" parent="">
        <item name="colorSurface">@color/bg_abyss</item>
        <item name="colorOnSurface">@color/text_hint</item>
        <item name="colorPrimary">@color/neon_violet</item>
    </style>

    <!-- Keep old alias -->
    <style name="CyberpunkBottomNavigation" parent="BottomNav.Neon" />
    <style name="ThemeOverlay.Cyberpunk.BottomNavigation" parent="ThemeOverlay.BottomNav.Neon" />


    <!-- ══════════════════════════════════════════════════
         TOOLBAR
    ══════════════════════════════════════════════════ -->
    <style name="Toolbar.Neon" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="android:background">@color/bg_abyss</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="CyberpunkToolbar" parent="Toolbar.Neon" />


    <!-- ══════════════════════════════════════════════════
         TEXT INPUT
    ══════════════════════════════════════════════════ -->
    <style name="TextInput.Neon" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/neon_violet</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="hintTextColor">@color/neon_violet</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="boxBackgroundColor">@color/bg_card</item>
        <item name="cursorColor">@color/neon_violet</item>
    </style>

    <style name="CyberpunkTextInput" parent="TextInput.Neon" />

    <style name="CyberpunkTextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">@null</item>
        <item name="android:padding">12dp</item>
    </style>


    <!-- ══════════════════════════════════════════════════
         FAB
    ══════════════════════════════════════════════════ -->
    <style name="FAB.Neon" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="tint">@color/neon_violet</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="CyberpunkFAB" parent="FAB.Neon" />

    <!-- Toolbar title appearance -->
    <style name="TextAppearance.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <!-- Neon-themed MaterialAlertDialog -->
    <style name="Dialog.Neon" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/bg_card</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorPrimary">@color/neon_violet</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Btn.Neon.Filled</item>
        <item name="buttonBarNegativeButtonStyle">@style/Btn.Danger</item>
        <item name="materialAlertDialogTitleTextStyle">@style/AlertDialog.TitleText</item>
    </style>

    <style name="AlertDialog.TitleText" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Neon seekbar progress tint (applied via progressTint attr in layouts) -->
    <style name="Seekbar.Neon" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressTint">@color/neon_violet</item>
        <item name="android:thumbTint">@color/neon_violet</item>
    </style>

</resources>
