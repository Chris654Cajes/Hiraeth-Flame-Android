<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#339D00FF" />
            <stroke android:width="2dp" android:color="#BF5FFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#0D020206" />
            <stroke android:width="1.5dp" android:color="#9D00FF" />
        </shape>
    </item>
</selector>
