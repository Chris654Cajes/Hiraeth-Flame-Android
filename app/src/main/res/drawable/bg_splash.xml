<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#030303" />
        </shape>
    </item>
    <!-- Soft top-left rose / pink glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.12"
                android:centerY="0.1"
                android:endColor="#00000000"
                android:gradientRadius="340dp"
                android:startColor="#5c007d"
                android:type="radial" />
        </shape>
    </item>
    <!-- Bottom-left teal / cyan glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.08"
                android:centerY="0.92"
                android:endColor="#00000000"
                android:gradientRadius="380dp"
                android:startColor="#000000"
                android:type="radial" />
        </shape>
    </item>
    <!-- Bottom-right deep purple / blue glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.9"
                android:centerY="0.88"
                android:endColor="#00000000"
                android:gradientRadius="360dp"
                android:startColor="#303030"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
