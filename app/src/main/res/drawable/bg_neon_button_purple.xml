<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_purple_dark" />
            <stroke android:width="3dp" android:color="@color/neon_purple_bright" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/purple_accent" />
            <stroke android:width="2dp" android:color="@color/neon_purple_bright" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/purple_accent" />
            <stroke android:width="2dp" android:color="@color/border_neon_purple" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
