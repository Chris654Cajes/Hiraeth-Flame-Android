<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HiraethFlame" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Cyberpunk Neon Colors - Purple Accent Theme -->
        <item name="colorPrimary">@color/purple_accent</item>
        <item name="colorOnPrimary">@color/cyberpunk_black</item>
        <item name="colorSecondary">@color/neon_cyan</item>
        <item name="colorOnSecondary">@color/cyberpunk_black</item>
        <item name="colorTertiary">@color/neon_magenta</item>
        <item name="colorOnTertiary">@color/cyberpunk_black</item>
        
        <!-- Surface Colors -->
        <item name="colorSurface">@color/cyberpunk_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/cyberpunk_card</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/cyberpunk_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        
        <!-- Status and Navigation Bar -->
        <item name="android:statusBarColor">@color/cyberpunk_black</item>
        <item name="android:navigationBarColor">@color/cyberpunk_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Button Styles -->
        <item name="colorPrimaryContainer">@color/neon_purple_dark</item>
        <item name="colorOnPrimaryContainer">@color/text_neon_purple</item>
        <item name="colorSecondaryContainer">@color/cyberpunk_card</item>
        <item name="colorOnSecondaryContainer">@color/text_neon_cyan</item>
        
        <!-- Border and Outline -->
        <item name="colorOutline">@color/border_neon_purple</item>
        <item name="colorOutlineVariant">@color/divider_cyberpunk</item>
        
        <!-- Cyberpunk Typography -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        
        <!-- Material Components Styling -->
        <item name="materialButtonStyle">@style/CyberpunkButton</item>
        <item name="materialCardViewStyle">@style/CyberpunkCard</item>
        <item name="bottomNavigationStyle">@style/CyberpunkBottomNavigation</item>
        <item name="toolbarStyle">@style/CyberpunkToolbar</item>
        <item name="textInputStyle">@style/CyberpunkTextInput</item>
        <item name="floatingActionButtonStyle">@style/CyberpunkFAB</item>
    </style>
    
    <!-- Cyberpunk Button Style -->
    <style name="CyberpunkButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/purple_accent</item>
        <item name="backgroundTint">#00000000</item>
        <item name="strokeColor">@color/purple_accent</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:elevation">0dp</item>
    </style>
    
    <!-- Cyberpunk Tonal Button Style -->
    <style name="CyberpunkTonalButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textColor">@color/purple_accent</item>
        <item name="backgroundTint">#00000000</item>
        <item name="strokeColor">@color/purple_accent</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:elevation">0dp</item>
    </style>
    
    <!-- Cyberpunk Card Style -->
    <style name="CyberpunkCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/cyberpunk_card</item>
        <item name="strokeColor">@color/border_neon_cyan</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <!-- Cyberpunk Bottom Navigation -->
    <style name="CyberpunkBottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.Cyberpunk.BottomNavigation</item>
    </style>
    
    <style name="ThemeOverlay.Cyberpunk.BottomNavigation" parent="">
        <item name="colorSurface">@color/cyberpunk_elevated</item>
        <item name="colorOnSurface">@color/text_secondary</item>
        <item name="colorPrimary">@color/purple_accent</item>
        <item name="colorSecondary">@color/neon_cyan</item>
        <item name="colorTertiary">@color/neon_magenta</item>
    </style>
    
    <!-- Cyberpunk Toolbar -->
    <style name="CyberpunkToolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_neon_purple</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="android:background">@color/cyberpunk_surface</item>
        <item name="android:elevation">4dp</item>
    </style>
    
    <!-- Cyberpunk Text Input -->
    <style name="CyberpunkTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/purple_accent</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/purple_accent</item>
        <item name="android:textColorHint">@color/purple_accent</item>
        <item name="android:textColor">@color/purple_accent</item>
        <item name="boxBackgroundColor">#00000000</item>
    </style>
    
    <!-- Cyberpunk TextInputEditText without underline -->
    <style name="CyberpunkTextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/purple_accent</item>
        <item name="boxStrokeColor">@color/purple_accent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxBackgroundColor">#00000000</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="android:background">@null</item>
        <item name="android:padding">12dp</item>
    </style>
    
    <!-- Cyberpunk FAB -->
    <style name="CyberpunkFAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">#00000000</item>
        <item name="tint">@color/purple_accent</item>
        <item name="android:elevation">6dp</item>
    </style>
</resources>
